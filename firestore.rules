rules_version = '2';

// ════════════════════════════════════════════════════════
// 3D 列印機預約系統 + 庫存管理 — Firestore Security Rules
//
// Collections:
//   users               - 使用者帳號與角色
//   bookings            - 預約資料
//   inventory/main      - 庫存單一文件（樹脂罐、備料、安全庫存、防重清單）
//   inventory_history   - 消耗/入庫/手動調整紀錄
//
// 角色：
//   admin  - 全部編輯、管理使用者
//   editor - 新增/編輯/刪除預約與庫存
//   viewer - 只能讀
//
// 預設 admin email: jiliao@swtc.com
// ════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── 工具函式 ─────────────────────────────────
    function isLoggedIn() {
      return request.auth != null;
    }
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() {
      return isLoggedIn() && getUserRole() == 'admin';
    }
    function isEditorOrAdmin() {
      return isLoggedIn() && (getUserRole() == 'editor' || getUserRole() == 'admin');
    }
    function isDefaultAdmin() {
      return isLoggedIn() && request.auth.token.email == 'jiliao@swtc.com';
    }

    // ── users collection ────────────────────────
    match /users/{userId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() && (
        (request.auth.uid == userId && (
          request.resource.data.role == 'viewer'
          || (isDefaultAdmin() && request.resource.data.role == 'admin')
        ))
        || isAdmin()
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── bookings collection ─────────────────────
    match /bookings/{bookingId} {
      allow read: if isLoggedIn();
      allow create, update, delete: if isEditorOrAdmin();
    }

    // ── inventory（單一文件，存樹脂罐/備料/安全庫存）─
    match /inventory/{docId} {
      allow read: if isLoggedIn();
      allow write: if isEditorOrAdmin();
    }

    // ── inventory_history（消耗、入庫、調整紀錄）──
    match /inventory_history/{logId} {
      allow read: if isLoggedIn();
      allow create: if isEditorOrAdmin();
      // 歷史紀錄通常不該被修改，只 admin 可改/刪以便除錯
      allow update, delete: if isAdmin();
    }

    // ── printer_status（單一 doc，Cloud Function 寫入、所有登入者讀）──
    match /printer_status/{docId} {
      allow read: if isLoggedIn();
      allow write: if false;  // 只允許 Cloud Function（用 admin SDK）寫入
    }

    // ── 預設拒絕 ─────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
