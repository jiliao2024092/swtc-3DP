rules_version = '2';

// ════════════════════════════════════════════════════════
// SWTC Portal — Firestore Security Rules（統一 swtc-3dp-poc）
//
// 整合後 Collections：
//   users               - 使用者帳號（permissions array，相容舊 role）
//   bookings            - 3D 列印機預約（swtc-3DP 原系統）
//   inventory/main      - 庫存單一文件
//   inventory_history   - 消耗/入庫/手動調整紀錄
//   printer_status      - Cloud Function 寫入的機台狀態
//   workboard_orders    - 工作看板工單（Coffee-Who 平台）
//   issues_anomalies    - 客戶異常
//   issues_ipa          - IPA 採購
//   issues_equipment    - 設備清單
//   settings/workspace  - 平台共用設定（工程師/機台/業務/借用人清單）
//
// 權限模型（7 種細權限，存在 users/{uid}.permissions array）：
//   view_board edit_board delete_board
//   view_issues edit_issues delete_issues
//   admin（擁有一切）
// ════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function perms() {
      return isLoggedIn() ? userDoc().get('permissions', []) : [];
    }
    function legacyRole() {
      return isLoggedIn() ? userDoc().get('role', 'viewer') : 'viewer';
    }
    function hasPerm(p) {
      return isLoggedIn() && (
        perms().hasAny(['admin', p])
        || legacyRole() == 'admin'
      );
    }
    function isAdmin() {
      return hasPerm('admin');
    }
    function isLegacyEditorOrAdmin() {
      return isLoggedIn() && (
        legacyRole() == 'editor' || legacyRole() == 'admin'
        || perms().hasAny(['admin','edit_board','edit_issues'])
      );
    }
    function isDefaultAdmin() {
      return isLoggedIn() && request.auth.token.email == 'jiliao@swtc.com';
    }

    match /users/{userId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() && (
        (request.auth.uid == userId)
        || isAdmin()
      );
      allow update, delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isLoggedIn();
      allow create, update, delete: if isLegacyEditorOrAdmin();
    }

    match /inventory/{docId} {
      allow read: if isLoggedIn();
      allow write: if isLegacyEditorOrAdmin();
    }

    match /inventory_history/{logId} {
      allow read: if isLoggedIn();
      allow create: if isLegacyEditorOrAdmin();
      allow update, delete: if isAdmin();
    }

    match /printer_status/{docId} {
      allow read: if isLoggedIn();
      allow write: if false;
    }

    match /workboard_orders/{orderId} {
      allow read: if hasPerm('view_board');
      allow create, update: if hasPerm('edit_board');
      allow delete: if hasPerm('delete_board');
    }

    match /issues_anomalies/{id} {
      allow read: if hasPerm('view_issues');
      allow create, update: if hasPerm('edit_issues');
      allow delete: if hasPerm('delete_issues');
    }
    match /issues_ipa/{id} {
      allow read: if hasPerm('view_issues');
      allow create, update: if hasPerm('edit_issues');
      allow delete: if hasPerm('delete_issues');
    }
    match /issues_equipment/{id} {
      allow read: if hasPerm('view_issues');
      allow create, update: if hasPerm('edit_issues');
      allow delete: if hasPerm('delete_issues');
    }

    match /settings/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
